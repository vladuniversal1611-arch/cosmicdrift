{
  "appId": "com.dragonblast.game",
  "appName": "Dragon Merge Blast",
  "webDir": "www",
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#120a28"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#120a28",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#120a28",
      "overlaysWebView": true
    }
  }
}
